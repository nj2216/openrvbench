BANNER = r"""
  ___                   _______      ______                  _
 / _ \ _ __   ___ _ __ |  __ \ \    / / __ )  ___ _ __   ___| |__
| | | | '_ \ / _ \ '_ \| |__) \ \  / / |  _ \ / _ \ '_ \ / __| '_ \
| |_| | |_) |  __/ | | |  _  / \ \/ /| |_) |  __/ | | | (__| | | |
 \___/| .__/ \___|_| |_|_| \_\  \__/|____/ \___|_| |_|\___|_| |_|
      |_|    RISC-V Benchmark Suite v1.0
"""

def print_banner():
    print(cyan(BANNER))

def fmt_metric(m: dict) -> str:
    val = m.get("value")
    unit = m.get("unit", "")
    if isinstance(val, float):
        val_str = f"{val:.2f}"
    elif isinstance(val, bool):
        val_str = "yes" if val else "no"
    else:
        val_str = str(val)
    return f"{val_str} {unit}".strip()

def print_board_info(info: dict):
    print()
    print(bold("─── System Information " + "─" * 50))
    print(f"  {'Board':<18} {cyan(info.get('board', 'unknown'))}")
    print(f"  {'ISA':<18} {info.get('isa', 'unknown')}")
    rvv_str = green("✓ RVV available") if info.get("has_rvv") else yellow("✗ No RVV")
    print(f"  {'Vector Ext':<18} {rvv_str}")
    print(f"  {'CPU Cores':<18} {info.get('cores', '?')}")
    print(f"  {'RAM':<18} {info.get('ram_gb', '?')} GB")
    print(f"  {'Kernel':<18} {info.get('kernel', 'unknown')}")
    print(f"  {'OS':<18} {info.get('os', 'unknown')}")
    if "cpu_freq_mhz" in info:
        print(f"  {'Max CPU Freq':<18} {info['cpu_freq_mhz']} MHz")
    print()

def print_result_summary(result: dict):
    bid  = result.get("bench_id",   "?")
    name = result.get("bench_name", bid)
    ok   = result.get("passed", False)
    score     = result.get("score", 0.0)
    score_unit = result.get("score_unit", "pts")
    dur  = result.get("duration_sec", 0.0)

    status = green("✓ PASS") if ok else red("✗ FAIL")

    print(f"\n{bold('─── ' + name + ' ' + '─' * max(1, 54 - len(name)))}")
    print(f"  Status   : {status}   Duration: {dim(f'{dur:.1f}s')}")

    if not ok:
        print(f"  {red('Error')}    : {result.get('error', '')}")
        return

    print(f"  {bold('Score')}    : {green(f'{score:.1f}')} {score_unit}")

    metrics = result.get("metrics", [])
    # Group by pairs for compact display
    pairs = []
    for m in metrics:
        if not isinstance(m.get("value"), bool):
            pairs.append(m)

    for m in pairs:
        name_w = m.get("name", "?").replace("_", " ")
        val    = fmt_metric(m)
        desc   = m.get("desc", "")
        print(f"  {dim(name_w + ':'): <30} {val: <16} {dim(desc)}")

def print_full_summary(board_info: dict, all_results: list):
    print()
    print(bold("═" * 70))
    print(bold("  OpenRVBench Results Summary"))
    print(bold("═" * 70))
    print(f"  Board    : {cyan(board_info.get('board', 'unknown'))}")
    print(f"  Date     : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}")
    print()

    col_w = 30
    score_w = 12
    print(f"  {'Benchmark':<{col_w}} {'Score':>{score_w}}  {'Unit':<8}  Status")
    print("  " + "─" * 65)

    total_score = 0.0
    ran = 0
    for r in all_results:
        bid   = r.get("bench_id", "?")
        bname = BENCH_REGISTRY.get(bid, ("", r.get("bench_name", bid), 0))[1]
        score = r.get("score", 0.0)
        unit  = r.get("score_unit", "pts")
        ok    = r.get("passed", False)

        status_sym = green("✓") if ok else red("✗")
        score_str  = f"{score:.1f}" if ok else "—"
        print(f"  {bname:<{col_w}} {score_str:>{score_w}}  {unit:<8}  {status_sym}")

        if ok:
            total_score += score
            ran += 1

    print("  " + "─" * 65)
    print(f"  {'Benchmarks run':<{col_w}} {ran:>{score_w}}")
    print()
    print(f"  {bold('Overall Score')} : {green(bold(f'{total_score:.1f}'))} pts")
    print(bold("═" * 70))
    print()

# ─────────────────────────────────────────────────────────────────────────────
# RESULT FILE MANAGEMENT
# ─────────────────────────────────────────────────────────────────────────────
def results_dir() -> pathlib.Path:
    # Prefer XDG_DATA_HOME if set, otherwise ~/.local/share/openrvbench/results
    # This is safe whether the CLI is run as root (saves to /root/...) or a
    # normal user, and never writes into /usr/local/bin/.
    xdg = os.environ.get("XDG_DATA_HOME", "")
    if xdg:
        base = pathlib.Path(xdg)
    else:
        base = pathlib.Path.home() / ".local" / "share"
    p = base / "openrvbench" / "results"
    p.mkdir(parents=True, exist_ok=True)
    return p

def save_result(board_info: dict, bench_results: list) -> pathlib.Path:
    ts   = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    name = board_info.get("board", "unknown").replace(" ", "_").replace("/", "-")
    name = re.sub(r"[^\w\-]", "", name)[:30]
    fname = results_dir() / f"{name}_{ts}.json"

    payload = {
        "version":     "1.0",
        "timestamp":   datetime.datetime.now().isoformat(),
        "board":       board_info,
        "benchmarks":  bench_results,
    }
    fname.write_text(json.dumps(payload, indent=2))
    return fname

# ─────────────────────────────────────────────────────────────────────────────
# COMPARE SUBCOMMAND
# ─────────────────────────────────────────────────────────────────────────────
def cmd_compare(args):
    result_path = pathlib.Path(args.path)
    files = []

    if result_path.is_dir():
        files = sorted(result_path.glob("*.json"))
    elif result_path.is_file():
        files = [result_path]
    else:
        print(red(f"Path not found: {result_path}"))
        sys.exit(1)

    if not files:
        print(yellow("No result files found."))
        return

    records = []
    for f in files:
        try:
            data = json.loads(f.read_text())
            records.append(data)
        except Exception as e:
            print(yellow(f"Skip {f.name}: {e}"))

    if not records:
        print(red("No valid result files."))
        return

    # Collect all bench IDs
    bench_ids = []
    for r in records:
        for b in r.get("benchmarks", []):
            bid = b.get("bench_id")
            if bid and bid not in bench_ids:
                bench_ids.append(bid)

    # Print comparison table
    print_banner()
    print(bold("\n  Benchmark Comparison\n"))

    col = 22
    header = f"  {'Board':<{col}}"
    for bid in bench_ids:
        header += f"  {bid.upper():>10}"
    print(bold(header))
    print("  " + "─" * (col + 14 * len(bench_ids)))

    for rec in records:
        board_name = rec.get("board", {}).get("board", "?")[:col-1]
        row = f"  {board_name:<{col}}"
        bench_map = {b["bench_id"]: b for b in rec.get("benchmarks", [])}
        for bid in bench_ids:
            b = bench_map.get(bid)
            if b and b.get("passed"):
                row += f"  {b['score']:>10.1f}"
            else:
                row += f"  {'—':>10}"
        print(row)

    print()

# ─────────────────────────────────────────────────────────────────────────────
# INFO SUBCOMMAND
# ─────────────────────────────────────────────────────────────────────────────
def cmd_info(args):
    print_banner()
    info = detect_board()
    print_board_info(info)
    bench_dir = find_bench_dir()
    print(bold("─── Available Benchmarks " + "─" * 46))
    print(f"  Binary search path: {dim(str(bench_dir))}")
    print()
    for bid, (bname, desc, timeout) in BENCH_REGISTRY.items():
        binary = find_binary(bid, bench_dir)
        avail  = green("✓") if binary else red("✗")
        path   = str(binary) if binary else yellow("not built")
        print(f"  {avail} {bold(bid):<12} {desc:<45} {dim(path)}")
    print()

# ─────────────────────────────────────────────────────────────────────────────
# RUN SUBCOMMAND
# ─────────────────────────────────────────────────────────────────────────────
def cmd_run(args):
    print_banner()

    board_info = detect_board()
    print_board_info(board_info)

    bench_dir = find_bench_dir()

    # Resolve which benchmarks to run
    target = args.benchmark.lower()
    if target == "all":
        to_run = ALL_BENCHES
    elif target in BENCH_REGISTRY:
        to_run = [target]
    else:
        # Comma-separated list
        to_run = [b.strip() for b in target.split(",") if b.strip() in BENCH_REGISTRY]
        if not to_run:
            print(red(f"Unknown benchmark: '{target}'"))
            print(f"Available: {', '.join(ALL_BENCHES)}")
            sys.exit(1)

    # Skip thermal unless explicitly requested
    if target == "all" and not args.include_thermal:
        to_run = [b for b in to_run if b != "thermal", "extensions"]
        print(yellow("  (thermal benchmark skipped by default — use --include-thermal)"))
        print()

    extra_args: dict = {}
    if hasattr(args, "model_dir") and args.model_dir:
        extra_args["ai"] = [args.model_dir]

    all_results = []
    total = len(to_run)

    for i, bid in enumerate(to_run, 1):
        _, desc, _ = BENCH_REGISTRY[bid]
        print(f"  [{i}/{total}] Running {bold(bid)} — {dim(desc)} ...", flush=True)

        result = run_bench(bid, bench_dir,
                           extra_args=extra_args.get(bid),
                           timeout=getattr(args, "timeout", None))
        all_results.append(result)
        print_result_summary(result)

    # ── Full summary ──────────────────────────────────────────────────────
    print_full_summary(board_info, all_results)

    # ── Save results ──────────────────────────────────────────────────────
    if not getattr(args, "no_save", False):
        out_path = save_result(board_info, all_results)
        print(f"  Results saved → {cyan(str(out_path))}")

        # JSON output flag
        if getattr(args, "json", False):
            print()
            print(json.dumps({"board": board_info, "benchmarks": all_results},
                             indent=2))

        # HTML report
        if getattr(args, "html", None):
            html_path = pathlib.Path(args.html)
            generate_html_report(board_info, all_results, html_path)
            print(f"  HTML report   → {cyan(str(html_path))}")

    print()

# ─────────────────────────────────────────────────────────────────────────────
# REPORT SUBCOMMAND
# ─────────────────────────────────────────────────────────────────────────────
def cmd_report(args):
    src = pathlib.Path(args.result_file)
    if not src.exists():
        print(red(f"File not found: {src}"))
        sys.exit(1)

    data = json.loads(src.read_text())
    out  = pathlib.Path(args.output) if args.output else src.with_suffix(".html")

    generate_html_report(data.get("board", {}),
                         data.get("benchmarks", []),
                         out)
    print(green(f"HTML report written → {out}"))

# ─────────────────────────────────────────────────────────────────────────────
# HTML REPORT GENERATOR  (inlined — no external scripts/ dependency)
# Works correctly whether the CLI is run from source or installed to /usr/local/bin
# ─────────────────────────────────────────────────────────────────────────────
_SCORE_BASELINES = {
    "cpu": 2000.0, "vector": 500.0, "memory": 2000.0, "crypto": 500.0,
    "storage": 1000.0, "network": 5000.0, "ai": 1000.0, "thermal": 900.0,
}

def _rpt_fmt(v, precision=2):
    if isinstance(v, float): return f"{v:.{precision}f}"
    if isinstance(v, bool):  return "yes" if v else "no"
    return str(v)

def _metric_rows(metrics: list) -> str:
    rows = []
    for m in metrics:
        name = m.get("name", "").replace("_", " ").title()
        val  = _rpt_fmt(m.get("value", ""))
        unit = m.get("unit", "")
        desc = m.get("desc", "")
        rows.append(
            f'<tr><td class="mn">{name}</td>'
            f'<td class="mv">{val}</td>'
            f'<td class="mu">{unit}</td>'
            f'<td class="md">{desc}</td></tr>'
        )
    return "\n".join(rows)

def _bench_cards(bench_results: list) -> str:
    import json as _json
    cards = []
    icons = {"cpu":"⚙️","vector":"🧮","memory":"💾","crypto":"🔐",
             "storage":"📀","network":"🌐","ai":"🤖","thermal":"🌡️"}
    for r in bench_results:
        bid   = r.get("bench_id", "?")
        bname = r.get("bench_name", bid)
        ok_   = r.get("passed", False)
        score = r.get("score", 0.0)
        unit  = r.get("score_unit", "pts")
        dur   = r.get("duration_sec", 0.0)
        err   = r.get("error", "")
        scls  = "pass" if ok_ else "fail"
        stxt  = "PASS" if ok_ else "FAIL"
        icon  = icons.get(bid, "📊")

        err_html = f'<div class="bench-error">{err}</div>' if not ok_ and err else ""

        metric_html = ""
        if ok_:
            visible = [m for m in r.get("metrics", [])
                       if not isinstance(m.get("value"), bool)][:8]
            if visible:
                metric_html = (
                    '<table class="metric-table">'
                    '<tr><th>Metric</th><th>Value</th><th>Unit</th><th>Description</th></tr>'
                    + _metric_rows(visible) + '</table>'
                )

        cards.append(f'''
<div class="bench-card {scls}">
  <div class="bench-header">
    <span class="bench-icon">{icon}</span>
    <span class="bench-name">{bname}</span>
    <span class="bench-status {scls}">{stxt}</span>
  </div>
  <div class="bench-score">
    <span class="score-num">{_rpt_fmt(score, 1)}</span>
    <span class="score-unit">{unit}</span>
    <span class="bench-dur">({dur:.1f}s)</span>
  </div>
  {err_html}
  {metric_html}
</div>''')
    return "\n".join(cards)

def generate_html_report(board_info: dict, bench_results: list,
                          output_path) -> pathlib.Path:
    """Write a self-contained dark-mode HTML report. No external deps required."""
    import json as _json

    board_name = board_info.get("board", "Unknown Board")
    isa        = board_info.get("isa",   "unknown")
    cores      = board_info.get("cores", "?")
    ram        = board_info.get("ram_gb", "?")
    kernel     = board_info.get("kernel", "?")
    os_str     = board_info.get("os",    "?")
    has_rvv    = board_info.get("has_rvv", False)
    rvv_badge  = "✓ RVV" if has_rvv else "✗ No RVV"
    rvv_cls    = "badge-green" if has_rvv else "badge-yellow"
    date_str   = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")

    total_score = sum(r.get("score", 0) for r in bench_results if r.get("passed"))
    n_pass      = sum(1 for r in bench_results if r.get("passed"))
    n_total     = len(bench_results)
    bench_cards = _bench_cards(bench_results)

    # Radar data
    r_labels, r_values = [], []
    for r in bench_results:
        bid   = r.get("bench_id", "")
